# Coral Dev Board
CORAL_IP=192.168.1.100
CORAL_ZMQ_PORT=5555

# RTSP / video source (RTSP URL or local file path)
RTSP_URL=rtsp://192.168.1.50/stream

# ── LLM backend ───────────────────────────────────────────────────────────────
# Set LLM_BACKEND to "gemini" (default) or "openai" for a local/custom endpoint.
LLM_BACKEND=gemini

# Gemini backend (LLM_BACKEND=gemini)
# Auth: run `gcloud auth application-default login` before starting the server
GOOGLE_CLOUD_PROJECT=ai-datascience-354723
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenAI-compatible backend (LLM_BACKEND=openai)
# Works with vLLM, Ollama, LM Studio, or any OpenAI API-compatible server.
# OPENAI_BASE_URL=http://your-vm-ip:8000/v1
# OPENAI_API_KEY=local
# OPENAI_MODEL=your-model-name

# ── Coaching server ───────────────────────────────────────────────────────────
COACHING_HOST=0.0.0.0
COACHING_PORT=8000

# LLM call interval in seconds
VLM_INTERVAL_SECONDS=5
